{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": false,
    "types": ["node"],
    "typeRoots": ["../../apps/ti-studio/node_modules/@types", "../../node_modules/@types"],
    "baseUrl": ".",
    "paths": {
      "@oranje-wit/types": ["../../packages/types/src/index.ts"],
      "pg": ["../../apps/ti-studio/node_modules/@types/pg"],
      "@prisma/adapter-pg": ["../../node_modules/@prisma/adapter-pg"]
    }
  },
  "include": [
    "../seed-test-db.ts",
    "./hash.ts",
    "./jitter.ts",
    "./fotos.ts",
    "./memo-placeholders.ts",
    "./namenpool.ts",
    "./validatie.ts"
  ],
  "exclude": ["**/*.test.ts"]
}
