# === Database ===
DATABASE_URL=postgresql://user:password@host:5432/dbname
DIRECT_URL=postgresql://user:password@host:5432/dbname

# === Auth (NextAuth v5) ===
AUTH_SECRET=         # Genereer met: openssl rand -hex 32
AUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# === Google OAuth ===
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# === Email (optioneel) ===
EMAIL_LINK_SECRET=   # Min 32 tekens, voor HMAC smartlinks
EMAIL_SERVER=        # SMTP URL: smtp://user:pass@host:587

# === API Keys (optioneel) ===
ANTHROPIC_API_KEY=   # Voor Daisy AI-chat
CLEANUP_API_KEY=     # Voor cron cleanup endpoint

# === Railway (automatisch in productie) ===
# RAILWAY_GIT_COMMIT_SHA=  (gezet door Railway)
