{
  "name": "oranje-wit",
  "version": "1.0.0",
  "description": "c.k.v. Oranje Wit — Monorepo: Verenigingsmonitor + Team-Indeling",
  "private": true,
  "scripts": {
    "dev": "pnpm dev:web",
    "build": "pnpm build:web",
    "dev:web": "pnpm --filter @oranje-wit/web dev",
    "build:web": "pnpm --filter @oranje-wit/web build",
    "test:web": "pnpm --filter @oranje-wit/web test",
    "db:generate": "pnpm --filter @oranje-wit/database generate",
    "db:migrate": "pnpm --filter @oranje-wit/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @oranje-wit/database migrate:deploy",
    "db:migrate:status": "pnpm --filter @oranje-wit/database migrate:status",
    "db:ensure-views": "pnpm --filter @oranje-wit/database ensure-views",
    "db:push": "echo 'GEBLOKKEERD: db:push dropt de VIEW speler_seizoenen. Gebruik db:migrate.' && exit 1",
    "import": "npx tsx scripts/import/import-data.ts",
    "import:check": "npx tsx scripts/import/import-check.ts",
    "import:evaluaties": "npx tsx scripts/import/import-evaluaties.ts",
    "test:db": "npx tsx scripts/import/test-db.ts",
    "pipeline:verloop": "node scripts/js/bereken-verloop.js",
    "pipeline:cohorten": "node scripts/js/bereken-cohorten.js",
    "pipeline:signalering": "node scripts/js/genereer-signalering.js",
    "pipeline:export": "node scripts/js/export-voor-teamindeling.js",
    "sync:standen": "node -r dotenv/config scripts/js/sync-standen-knkv.js",
    "test": "pnpm -r run test",
    "test:ui": "pnpm --filter @oranje-wit/ui test",
    "test:e2e": "playwright test",
    "test:e2e:design-system": "playwright test --project=design-system",
    "test:e2e:ui": "playwright test --ui",
    "seed": "npx tsx -r dotenv/config e2e/fixtures/seed.ts",
    "seed:clean": "npx tsx -r dotenv/config e2e/fixtures/cleanup.ts",
    "seed:demo": "npx tsx -r ./scripts/env-local.js scripts/seed-demo-data.ts",
    "db:local:up": "docker compose up -d && echo 'Wacht op PostgreSQL...' && sleep 2 && pnpm db:migrate:deploy && pnpm db:ensure-views",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v && pnpm db:local:up && pnpm seed:demo",
    "db:prod:clean-demo": "npx tsx -r dotenv/config scripts/clean-demo-from-prod.ts",
    "lint": "pnpm -r run lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "verify:deploy": "tsx scripts/verify-deploy.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "dotenv": "^16.4.0",
    "pg": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-dom": "19.2.3"
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  }
}
