{
  "name": "oranje-wit",
  "version": "1.0.0",
  "description": "c.k.v. Oranje Wit — Monorepo: Verenigingsmonitor + Team-Indeling",
  "private": true,
  "scripts": {
    "dev:monitor": "pnpm --filter @oranje-wit/monitor dev",
    "dev:ti": "pnpm --filter @oranje-wit/team-indeling dev",
    "build:ti": "pnpm --filter @oranje-wit/team-indeling build",
    "build:monitor": "pnpm --filter @oranje-wit/monitor build",
    "db:generate": "pnpm --filter @oranje-wit/database generate",
    "db:migrate": "pnpm --filter @oranje-wit/database migrate:dev",
    "db:migrate:deploy": "pnpm --filter @oranje-wit/database migrate:deploy",
    "db:migrate:status": "pnpm --filter @oranje-wit/database migrate:status",
    "db:ensure-views": "pnpm --filter @oranje-wit/database ensure-views",
    "db:push": "echo 'GEBLOKKEERD: db:push dropt de VIEW speler_seizoenen. Gebruik db:migrate.' && exit 1",
    "import": "npx tsx scripts/import/import-data.ts",
    "import:check": "npx tsx scripts/import/import-check.ts",
    "import:evaluaties": "npx tsx scripts/import/import-evaluaties.ts",
    "test:db": "npx tsx scripts/import/test-db.ts",
    "pipeline:verloop": "node scripts/js/bereken-verloop.js",
    "pipeline:cohorten": "node scripts/js/bereken-cohorten.js",
    "pipeline:signalering": "node scripts/js/genereer-signalering.js",
    "pipeline:export": "node scripts/js/export-voor-teamindeling.js",
    "sync:standen": "node -r dotenv/config scripts/js/sync-standen-knkv.js",
    "status:ti": "npx tsx scripts/status-check-team-indeling.ts",
    "test": "pnpm -r run test",
    "test:monitor": "pnpm --filter @oranje-wit/monitor test",
    "test:ti": "pnpm --filter @oranje-wit/team-indeling test",
    "dev:evaluatie": "pnpm --filter @oranje-wit/evaluatie dev",
    "build:evaluatie": "pnpm --filter @oranje-wit/evaluatie build",
    "test:evaluatie": "pnpm --filter @oranje-wit/evaluatie test",
    "dev:scouting": "pnpm --filter @oranje-wit/scouting dev",
    "build:scouting": "pnpm --filter @oranje-wit/scouting build",
    "test:scouting": "pnpm --filter @oranje-wit/scouting test",
    "dev:beheer": "pnpm --filter @oranje-wit/beheer dev",
    "build:beheer": "pnpm --filter @oranje-wit/beheer build",
    "test:beheer": "pnpm --filter @oranje-wit/beheer test",
    "dev:portaal": "pnpm --filter @oranje-wit/portaal dev",
    "build:portaal": "pnpm --filter @oranje-wit/portaal build",
    "test:portaal": "pnpm --filter @oranje-wit/portaal test",
    "test:ui": "pnpm --filter @oranje-wit/ui test",
    "test:e2e": "playwright test",
    "test:e2e:ti": "playwright test --project=team-indeling",
    "test:e2e:monitor": "playwright test --project=monitor",
    "test:e2e:evaluatie": "playwright test --project=evaluatie",
    "test:e2e:scouting": "playwright test --project=scouting",
    "test:e2e:design-system": "playwright test --project=design-system",
    "test:e2e:ui": "playwright test --ui",
    "seed": "npx tsx -r dotenv/config e2e/fixtures/seed.ts",
    "seed:clean": "npx tsx -r dotenv/config e2e/fixtures/cleanup.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,mjs}": [
      "eslint --fix --max-warnings 0 --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,css}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.1",
    "dotenv": "^16.4.0",
    "pg": "^8.19.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1"
  }
}
