generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  VERENIGINGSMONITOR — gedeelde data (oranje-wit repo)    ║
// ║  Tabelnamen: snake_case (@@map)                          ║
// ╚═══════════════════════════════════════════════════════════╝

// Permanente ledenrecords (1 rij per lid, ooit ingeschreven)
model Lid {
  relCode          String    @id @map("rel_code")
  roepnaam         String
  achternaam       String
  tussenvoegsel    String?
  voorletters      String?
  geslacht         String    // "M" | "V"
  geboortejaar     Int?
  geboortedatum    DateTime? @db.Date
  lidSinds         DateTime? @map("lid_sinds") @db.Date
  afmelddatum      DateTime? @db.Date
  lidsoort         String?
  email            String?
  registratieDatum DateTime? @map("registratie_datum") @db.Date
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Relaties
  competitieSpelers CompetitieSpeler[]
  foto              LidFoto?
  stafleden         Staf[]

  @@map("leden")
}

// Profielfoto per lid (opgeslagen als webp binary)
model LidFoto {
  relCode         String    @id @map("rel_code")
  bronUrl         String?   @map("bron_url")
  imageWebp       Bytes     @map("image_webp")
  contentHash     String?   @map("content_hash")
  sourceUpdatedAt DateTime? @map("source_updated_at") @db.Timestamptz(6)
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime? @default(now()) @map("updated_at") @db.Timestamptz(6)

  // Relaties
  lid Lid @relation(fields: [relCode], references: [relCode], onDelete: Cascade)

  @@map("lid_fotos")
}

// Seizoenstatus: planning → actief → afgerond
enum SeizoenStatus {
  VOORBEREIDING
  ACTIEF
  AFGEROND
}

// Seizoenen
model Seizoen {
  seizoen    String        @id
  startJaar  Int           @map("start_jaar")
  eindJaar   Int           @map("eind_jaar")
  startDatum DateTime      @map("start_datum") @db.Date  // 1 augustus
  eindDatum  DateTime      @map("eind_datum") @db.Date   // 30 juni
  peildatum  DateTime      @map("peildatum") @db.Date    // 31 december van startJaar
  status     SeizoenStatus @default(VOORBEREIDING) @map("status")

  // Relaties
  owTeams            OWTeam[]
  competitieSpelers  CompetitieSpeler[]
  competitieRondes   CompetitieRonde[]
  ledenverloop       Ledenverloop[]
  cohortSeizoenen    CohortSeizoen[]
  signaleringen      Signalering[]
  poolStanden        PoolStand[]
  mijlpalen          Mijlpaal[]

  @@map("seizoenen")
}

// Teams per seizoen (stabiel via owCode)
model OWTeam {
  id             Int      @id @default(autoincrement())
  seizoen        String
  owCode         String   @map("ow_code")
  naam           String?
  categorie      String   // "a" | "b"
  kleur          String?
  leeftijdsgroep String?
  spelvorm       String?
  isSelectie     Boolean  @default(false) @map("is_selectie")
  selectieOwCode String?  @map("selectie_ow_code")
  sortOrder      Int?     @map("sort_order")

  // Relaties
  seizoenRef Seizoen       @relation(fields: [seizoen], references: [seizoen])
  periodes   TeamPeriode[]
  aliases    TeamAlias[]
  coordinatoren  CoordinatorTeam[]
  uitnodigingen  EvaluatieUitnodiging[]
  scoutingSessies TeamScoutingSessie[]

  @@unique([seizoen, owCode])
  @@index([seizoen], map: "idx_teams_seizoen")
  @@map("teams")
}

// Team-periodedata (J-nummer, pool, sterkte per competitiefase)
model TeamPeriode {
  id            Int      @id @default(autoincrement())
  teamId        Int      @map("team_id")
  periode       String   // "veld_najaar" | "zaal_deel1" | "zaal_deel2" | "veld_voorjaar"
  jNummer       String?  @map("j_nummer")
  pool          String?
  sterkte       Int?
  gemLeeftijd   Decimal? @map("gem_leeftijd") @db.Decimal(5, 2)
  aantalSpelers Int?     @map("aantal_spelers")

  // Relaties
  owTeam OWTeam @relation(fields: [teamId], references: [id])

  @@unique([teamId, periode])
  @@index([teamId], map: "idx_team_periodes_team")
  @@map("team_periodes")
}

// KNKV-naam aliases die naar een OWTeam verwijzen
// Gevuld bij team-sync; vervangt de runtime team_mapping CTE
model TeamAlias {
  id       Int    @id @default(autoincrement())
  seizoen  String
  alias    String // "J1", "OW J1", "S1", "S1/S2", "Kangoeroes", etc.
  owTeamId Int    @map("ow_team_id")
  owCode   String @map("ow_code") // gedenormaliseerd: stabiel per seizoen

  owTeam OWTeam @relation(fields: [owTeamId], references: [id], onDelete: Cascade)

  @@unique([seizoen, alias])
  @@index([seizoen, alias])
  @@map("team_aliases")
}

// Competitierondes per seizoen (welke periodes zijn gespeeld)
model CompetitieRonde {
  id        Int      @id @default(autoincrement())
  seizoen   String
  periode   String   // "veld_najaar" | "zaal" | "zaal_deel1" | "zaal_deel2" | "veld_voorjaar"
  spelvorm  String?  // "8-korfbal" | "4-korfbal" | null
  volgorde  Int      // 1, 2, 3, 4

  seizoenRef Seizoen @relation(fields: [seizoen], references: [seizoen])

  @@unique([seizoen, periode])
  @@map("competitie_rondes")
}

// Speler × team × competitieronde (primaire tabel)
// VIEW speler_seizoenen leidt hieruit af: DISTINCT ON (rel_code, seizoen)
model CompetitieSpeler {
  id          Int      @id @default(autoincrement())
  relCode     String   @map("rel_code")
  seizoen     String
  competitie  String   // "veld_najaar" | "zaal" | "veld_voorjaar"
  team        String
  geslacht    String?  // "M" | "V"
  bron        String   // "telling"
  betrouwbaar Boolean  @default(true)

  lid        Lid      @relation(fields: [relCode], references: [relCode])
  seizoenRef Seizoen  @relation(fields: [seizoen], references: [seizoen])

  @@unique([relCode, seizoen, competitie])
  @@index([seizoen], map: "idx_cs_seizoen")
  @@index([relCode], map: "idx_cs_relcode")
  @@map("competitie_spelers")
}

// Ledenverloop (individueel per seizoenspaar)
model Ledenverloop {
  id            Int     @id @default(autoincrement())
  seizoen       String
  relCode       String  @map("rel_code")
  status        String  // "behouden" | "nieuw" | "herinschrijver" | "uitgestroomd" | "niet_spelend_geworden"
  geboortejaar  Int?
  geslacht      String?
  leeftijdVorig Int?    @map("leeftijd_vorig")
  leeftijdNieuw Int?    @map("leeftijd_nieuw")
  teamVorig     String? @map("team_vorig")
  teamNieuw     String? @map("team_nieuw")

  // Relaties
  seizoenRef Seizoen @relation(fields: [seizoen], references: [seizoen])

  @@unique([seizoen, relCode])
  @@index([seizoen], map: "idx_ledenverloop_seizoen")
  @@map("ledenverloop")
}

// Cohorten (geboortejaar × geslacht × seizoen)
model CohortSeizoen {
  id             Int      @id @default(autoincrement())
  geboortejaar   Int
  geslacht       String   // "M" | "V"
  seizoen        String
  leeftijd       Int?
  band           String?
  actief         Int?     @default(0)
  behouden       Int?     @default(0)
  nieuw          Int?     @default(0)
  herinschrijver Int?     @default(0)
  uitgestroomd   Int?     @default(0)
  retentiePct    Decimal? @map("retentie_pct") @db.Decimal(5, 2)

  // Relaties
  seizoenRef Seizoen @relation(fields: [seizoen], references: [seizoen])

  @@unique([geboortejaar, geslacht, seizoen])
  @@index([seizoen], map: "idx_cohort_seizoen")
  @@map("cohort_seizoenen")
}

// Signalering (alerts per seizoen)
model Signalering {
  id             Int      @id @default(autoincrement())
  seizoen        String
  type           String
  ernst          String   // "kritiek" | "aandacht" | "op_koers"
  leeftijdsgroep String?
  geslacht       String?
  waarde         Decimal? @db.Decimal
  drempel        Decimal? @db.Decimal
  streef         Decimal? @db.Decimal
  beschrijving   String?
  advies         String?

  // Relaties
  seizoenRef Seizoen @relation(fields: [seizoen], references: [seizoen])

  @@index([seizoen], map: "idx_signalering_seizoen")
  @@map("signalering")
}

// Streefmodel (projecties per leeftijd × doelseizoen)
model Streefmodel {
  id           Int    @id @default(autoincrement())
  versie       String
  seizoenBasis String @map("seizoen_basis")
  seizoenDoel  String @map("seizoen_doel")
  leeftijd     Int
  band         String
  totaal       Int?
  m            Int?
  v            Int?

  @@unique([versie, seizoenDoel, leeftijd])
  @@map("streefmodel")
}

// Competitiestand per poule per periode
model PoolStand {
  id           Int       @id @default(autoincrement())
  seizoen      String
  periode      String    // "veld_najaar" | "zaal" | "veld_voorjaar"
  pool         String    // "HK-08", "Ro-135", "1-12", etc.
  niveau       String?   // "Hoofdklasse", "Rood", "1e klasse", etc.
  regio        String?   // "ZWT" | "LND"
  standDatum   DateTime? @map("stand_datum") @db.Date
  bronBestand  String?   @map("bron_bestand")

  // Relaties
  seizoenRef Seizoen          @relation(fields: [seizoen], references: [seizoen])
  regels     PoolStandRegel[]

  @@unique([seizoen, periode, pool])
  @@index([seizoen], map: "idx_pool_stand_seizoen")
  @@map("pool_standen")
}

// Individuele teamregel in een poulestand
model PoolStandRegel {
  id              Int     @id @default(autoincrement())
  poolStandId     Int     @map("pool_stand_id")
  positie         Int
  teamNaam        String  @map("team_naam")
  isOW            Boolean @default(false) @map("is_ow")
  gespeeld        Int     @map("gs")
  gewonnen        Int     @map("wn")
  gelijk          Int     @map("gl")
  verloren        Int     @map("vl")
  punten          Int     @map("pt")
  doelpuntenVoor  Int     @map("vr")
  doelpuntenTegen Int     @map("tg")

  // Extensie-velden (later)
  teamscore       Decimal? @db.Decimal(6, 2)
  gemLeeftijd     Decimal? @map("gem_leeftijd") @db.Decimal(5, 2)

  // Relaties
  poolStand PoolStand @relation(fields: [poolStandId], references: [id], onDelete: Cascade)

  @@unique([poolStandId, positie])
  @@index([poolStandId], map: "idx_pool_stand_regel_stand")
  @@index([isOW], map: "idx_pool_stand_regel_ow")
  @@map("pool_stand_regels")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  TEAM-INDELING — procesdata (dit project)                ║
// ║  Tabelnamen: PascalCase (Prisma default)                 ║
// ╚═══════════════════════════════════════════════════════════╝

// ============================================================
// GEBRUIKERS & AUTH
// ============================================================

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  naam      String
  rol       Rol      @default(VIEWER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaties
  pins     Pin[]
  logItems LogEntry[]
  werkitems             Werkitem[]  @relation("WerkitemAuteur")
  actiepuntenGemaakt    Actiepunt[] @relation("ActiepuntAuteur")
  actiepuntenToegewezen Actiepunt[] @relation("ActiepuntToewijzing")
  activiteitenAuteur    Activiteit[] @relation("ActiviteitAuteur")
  activiteitenToewijzing Activiteit[] @relation("ActiviteitToewijzing")
  scoutProfiel          Scout?
  scoutingVerzoeken     ScoutingVerzoek[]
  gezienMarkeringen     BlauwdrukSpeler[] @relation("GezienDoor")
  besluitenGemaakt      BlauwdrukBesluit[] @relation("BesluitAuteur")
}

enum Rol {
  EDITOR      // TC-lid: volledige toegang
  COORDINATOR // Coördinator: ziet eigen doelgroep-besluiten + actiepunten
  REVIEWER    // Coach/trainer: bekijken + opmerkingen
  VIEWER      // Bestuur/inkijk: alleen lezen
}

// Centraal gebruikersbeheer — capabilities-based auth model
model Gebruiker {
  id          String      @id @default(cuid())
  email       String      @unique
  naam        String

  // Capabilities
  isTC        Boolean     @default(false) @map("is_tc")
  isTCKern    Boolean     @default(false) @map("is_tc_kern") // mag scenario's/pins bewerken
  isScout     Boolean     @default(false) @map("is_scout")
  clearance   Int         @default(0)     // 0-3, ingesteld door TC in Beheer
  doelgroepen Doelgroep[]                  // TC-lid: verantwoordelijk voor deze doelgroepen

  // Lifecycle
  actief      Boolean     @default(true)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("gebruikers")
}

// Verificatie-tokens voor magic links (NextAuth EmailProvider)
model VerificatieToken {
  identifier String   // email adres
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificatie_tokens")
}

// Tijdelijke toegangstokens voor evaluatie-uitnodigingen, scouting, etc.
model ToegangsToken {
  id          String    @id @default(cuid())
  token       String    @unique @default(cuid())
  email       String
  naam        String?   // naam van de respondent
  type        String    // "evaluatie" | "scouting" | etc.

  // Scope: waartoe geeft dit token toegang?
  scope       Json      // bijv. { rondeId: "xxx", teamId: 123 }

  // Lifecycle
  verlooptOp  DateTime  @map("verloopt_op")
  gebruiktOp  DateTime? @map("gebruikt_op")
  actief      Boolean   @default(true)

  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([token])
  @@map("toegangs_tokens")
}

// ============================================================
// SPELERS & STAF (geïmporteerd + verrijkt)
// ============================================================

model Speler {
  id            String  @id // Sportlink rel_code
  roepnaam      String
  achternaam    String
  geboortejaar  Int
  geboortedatum DateTime? @db.Date
  geslacht      Geslacht
  lidSinds      String?  // "2018-09-02"
  huidig         Json?   // { team, categorie, kleur, a_categorie, a_jaars, leeftijd }
  spelerspad    Json?    // Array: [{ seizoen, team, kleur, niveau, spelvorm, categorie }]
  volgendSeizoen Json?   // { leeftijd, a_categorie, a_jaars, band_b, opmerking }
  retentie       Json?   // { risico, kans_behoud, factoren[] }
  teamgenotenHistorie Json? // [{ speler_id, naam, seizoenen_samen }]
  seizoenenActief Int?
  instroomLeeftijd Int?
  status        SpelerStatus @default(BESCHIKBAAR)
  notitie       String? @db.Text
  rating          Int?
  ratingBerekend  Int?  @map("rating_berekend")

  // Relaties
  teamplaatsingen    TeamSpeler[]
  selectiePlaatsingen SelectieSpeler[]
  evaluaties         Evaluatie[]
  zelfEvaluaties     SpelerZelfEvaluatie[]
  pins               Pin[]
  werkitems          Werkitem[]
  activiteiten       Activiteit[]
  scoutingRapporten    ScoutingRapport[]
  spelersKaarten       SpelersKaart[]
  fysiekProfielen      FysiekProfiel[]
  spelerUSS            SpelerUSS[]
  vergelijkingPosities ScoutingVergelijkingPositie[]
  blauwdrukStatussen   BlauwdrukSpeler[]
  whatIfPlaatsingen     WhatIfTeamSpeler[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([geboortejaar])
  @@index([geslacht])
}

enum Geslacht {
  M
  V
}

model Staf {
  id           String  @id               // stafCode: STAF-001
  relCode      String? @unique @map("rel_code")  // optionele koppeling naar leden
  naam         String
  geboortejaar Int?
  email        String?
  rollen       String[] // ["trainer", "assistent", "manager", "coordinator"]
  notitie      String?  @db.Text

  // Relaties
  lid                 Lid?     @relation(fields: [relCode], references: [relCode])
  teamStaf            TeamStaf[]
  selectiePlaatsingen SelectieStaf[]
  pins                Pin[]
  toewijzingen        StafToewijzing[]
  werkitems           Werkitem[]
  activiteiten        Activiteit[]
  scoutProfiel        Scout?
  whatIfPlaatsingen   WhatIfTeamStaf[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Historische staf-toewijzing: wie bij welk team per seizoen (Monitor-domein)
model StafToewijzing {
  id       Int    @id @default(autoincrement())
  stafId   String @map("staf_id")
  seizoen  String
  team     String
  rol      String                    // "Trainer/Coach", "Begeleider", "Verzorger"
  functie  String?                   // originele functietekst uit CSV
  bron     String @default("staf_overzicht")

  staf     Staf   @relation(fields: [stafId], references: [id])

  @@unique([stafId, seizoen, team])
  @@index([seizoen])
  @@index([stafId])
  @@map("staf_toewijzingen")
}

// ============================================================
// BLAUWDRUK (per seizoen)
// ============================================================

model Blauwdruk {
  id            String   @id @default(cuid())
  seizoen       String   @unique // "2026-2027"
  isWerkseizoen Boolean  @default(false) // ★ het actieve planningseizoen
  toelichting   String?  @db.Text

  // Gestructureerde kaders
  kaders         Json     // KNKV-regels + OW-regels die dit seizoen gelden
  speerpunten    String[] // Seizoensdoelen
  keuzes         Json?    // Array van { id, vraag, opties: string[] }  @map("twijfelpunten")

  // Relaties
  concepten   Concept[]
  pins        Pin[]
  werkitems     Werkitem[]
  actiepunten   Actiepunt[]
  activiteiten  Activiteit[]

  blauwdrukSpelers BlauwdrukSpeler[]
  besluiten        BlauwdrukBesluit[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// BLAUWDRUK-SPELER (gezien-status per seizoen)
// ============================================================

model BlauwdrukSpeler {
  id           String   @id @default(cuid())
  blauwdruk    Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId  String
  speler       Speler   @relation(fields: [spelerId], references: [id])
  spelerId     String

  gezienStatus GezienStatus @default(ONGEZIEN)
  notitie      String?  @db.Text
  signalering  String?  // "DOORSTROOM_U15", "NAAR_SENIOREN", "VERLAAT_KLEUR", etc.

  // Optionele koppeling naar actiepunt (bij GEEL/ORANJE)
  actiepunt    Actiepunt? @relation(fields: [actiepuntId], references: [id])
  actiepuntId  String? @unique

  // Audit
  gezienDoor   User?    @relation("GezienDoor", fields: [gezienDoorId], references: [id])
  gezienDoorId String?
  gezienOp     DateTime?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([blauwdrukId, spelerId])
  @@index([blauwdrukId])
  @@index([spelerId])
  @@index([gezienStatus])
}

enum GezienStatus {
  ONGEZIEN
  GROEN   // Beschikbaar, geen twijfel
  GEEL    // Onzeker, moet uitgezocht
  ORANJE  // Stop-signalen
  ROOD    // Stopt definitief
}

// ============================================================
// BESLUITENLIJST (per seizoen)
// ============================================================

model StandaardVraag {
  id           String       @id @default(cuid())
  code         String       @unique // "TEAMS_SENIOREN_A", "SELECTIE_U15_ACTIEF"
  vraag        String       @db.Text
  groep        String       // "TEAMAANTALLEN" | "SELECTIESTRUCTUUR" | "BEZETTINGSGRAAD" | "DOORSTROOM"
  volgorde     Int          @default(0)
  actief       Boolean      @default(true)

  // Gestructureerde invoer
  antwoordType AntwoordType @default(TEKST)
  opties       String[]     // voor KEUZE: voorgedefinieerde opties
  toonAls      Json?        // conditie: { code: "TEAMS_U15", operator: ">=", waarde: 2 }

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

enum AntwoordType {
  TEKST        // Vrije tekst
  GETAL        // Numerieke invoer
  JA_NEE       // Boolean toggle
  KEUZE        // Selecteer uit opties[]
  GETAL_RANGE  // Drie getallen: ideaal M / ideaal V / afwijking
}

model BlauwdrukBesluit {
  id            String   @id @default(cuid())
  blauwdruk     Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId   String

  // De vraag
  vraag         String   @db.Text
  isStandaard   Boolean  @default(false) // true = uit StandaardVraag, false = TC-toegevoegd
  standaardCode String?  // link naar StandaardVraag.code
  volgorde      Int      @default(0)

  // Het antwoord
  antwoordType  AntwoordType @default(TEKST)
  antwoord      String?  @db.Text     // vrije toelichting
  antwoordWaarde Json?                // gestructureerd: getal, boolean, keuze-index, range
  opties        String[]              // voor KEUZE: voorgedefinieerde opties
  toonAls       Json?                 // conditie: { code, operator, waarde }
  groep         String?               // "TEAMAANTALLEN", "SELECTIESTRUCTUUR", etc.
  toelichting   String?  @db.Text

  // Metadata
  status        BesluitStatus @default(ONDUIDELIJK)
  niveau        BesluitNiveau @default(TECHNISCH)
  doelgroep     Doelgroep?

  // Audit
  auteur        User     @relation("BesluitAuteur", fields: [auteurId], references: [id])
  auteurId      String

  // Actiepunten die voortvloeien uit dit besluit
  actiepunten   Actiepunt[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([blauwdrukId])
  @@index([status])
}

enum BesluitStatus {
  ONDUIDELIJK // Moet nog besproken
  VOORLOPIG   // Richting bepaald, niet definitief
  DEFINITIEF  // Afgehamerd
}

enum BesluitNiveau {
  BESTUURLIJK // Bestuursbesluit
  TECHNISCH   // TC-besluit
}

// ============================================================
// PIN-SYSTEEM
// ============================================================

model Pin {
  id          String  @id @default(cuid())
  blauwdruk   Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId String

  type    PinType
  waarde  Json
  notitie String? @db.Text

  speler   Speler? @relation(fields: [spelerId], references: [id])
  spelerId String?
  staf     Staf?   @relation(fields: [stafId], references: [id])
  stafId   String?

  gepindDoor   User     @relation(fields: [gepindDoorId], references: [id])
  gepindDoorId String
  gepindOp     DateTime @default(now())

  @@index([blauwdrukId])
  @@index([type])
}

enum PinType {
  SPELER_STATUS
  SPELER_POSITIE
  STAF_POSITIE
}

// ============================================================
// CONCEPTEN
// ============================================================

model Concept {
  id              String    @id @default(cuid())
  blauwdruk       Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId     String

  naam            String
  uitgangsprincipe String   @db.Text
  keuzes          Json
  aannames        Json?

  status          ConceptStatus @default(ACTIEF)
  volgorde        Int       @default(0)

  // Relaties
  scenarios Scenario[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blauwdrukId])
}

enum ConceptStatus {
  ACTIEF
  GEARCHIVEERD
  DEFINITIEF
}

// ============================================================
// SCENARIO'S
// ============================================================

model Scenario {
  id          String  @id @default(cuid())
  concept     Concept @relation(fields: [conceptId], references: [id], onDelete: Cascade)
  conceptId   String

  naam          String
  toelichting   String?  @db.Text
  aannames      Json?
  keuzeWaardes  Json?    // { [keuzeId]: gekozenOptie }

  status          ScenarioStatus @default(ACTIEF)
  isWerkindeling  Boolean        @default(false)

  parentId String?
  parent   Scenario?  @relation("ScenarioFork", fields: [parentId], references: [id])
  children Scenario[] @relation("ScenarioFork")

  // Relaties
  versies  Versie[]
  werkitems Werkitem[]
  whatIfs   WhatIf[]

  verwijderdOp DateTime? // soft-delete: null = actief, set = verwijderd

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conceptId])
}

// Snapshot van scenario-data voor herstel na verwijdering
model ScenarioSnapshot {
  id            String @id @default(cuid())
  scenarioId    String // geen FK — snapshot overleeft hard-delete
  naam          String
  reden         String // VERWIJDERD | HANDMATIG | PRE_DEFINITIEF
  data          Json   // volledige scenario-data (versies, teams, spelers, staf)
  aantalTeams   Int    @default(0)
  aantalSpelers Int    @default(0)
  auteur        String?

  createdAt DateTime @default(now())

  @@index([scenarioId])
}

enum ScenarioStatus {
  ACTIEF
  GEARCHIVEERD
  DEFINITIEF
}

// ============================================================
// VERSIES (snapshots binnen een scenario)
// ============================================================

model Versie {
  id         String   @id @default(cuid())
  scenario   Scenario @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId String

  nummer   Int
  naam     String?
  auteur   String
  posities Json?

  // Relaties
  teams           Team[]
  selectieGroepen SelectieGroep[]
  logItems        LogEntry[]

  createdAt DateTime @default(now())

  @@unique([scenarioId, nummer])
  @@index([scenarioId])
}

// ============================================================
// TEAMS (binnen een versie)
// ============================================================

model Team {
  id       String @id @default(cuid())
  versie   Versie @relation(fields: [versieId], references: [id], onDelete: Cascade)
  versieId String

  naam      String
  alias     String?
  categorie TeamCategorie
  kleur     Kleur?
  teamType  TeamType?
  niveau    String?
  volgorde  Int      @default(0)

  validatieStatus    ValidatieStatus @default(ONBEKEND)
  validatieMeldingen Json?

  // Selectie-koppeling
  selectieGroepId String?
  selectieGroep   SelectieGroep? @relation(fields: [selectieGroepId], references: [id], onDelete: SetNull)

  // Relaties
  spelers       TeamSpeler[]
  staf          TeamStaf[]
  whatIfKopieen WhatIfTeam[]

  @@index([versieId])
}

// ============================================================
// SELECTIEGROEPEN (koppeling van teams in een selectie)
// ============================================================

model SelectieGroep {
  id       String @id @default(cuid())
  versie   Versie @relation(fields: [versieId], references: [id], onDelete: Cascade)
  versieId String

  naam     String?

  teams    Team[]
  spelers  SelectieSpeler[]
  staf     SelectieStaf[]

  @@index([versieId])
}

model SelectieSpeler {
  id              String        @id @default(cuid())
  selectieGroep   SelectieGroep @relation(fields: [selectieGroepId], references: [id], onDelete: Cascade)
  selectieGroepId String
  speler          Speler        @relation(fields: [spelerId], references: [id])
  spelerId        String

  statusOverride  SpelerStatus?
  notitie         String?       @db.Text

  @@unique([selectieGroepId, spelerId])
  @@index([selectieGroepId])
  @@index([spelerId])
}

model SelectieStaf {
  id              String        @id @default(cuid())
  selectieGroep   SelectieGroep @relation(fields: [selectieGroepId], references: [id], onDelete: Cascade)
  selectieGroepId String
  staf            Staf          @relation(fields: [stafId], references: [id])
  stafId          String

  rol             String

  @@unique([selectieGroepId, stafId])
  @@index([selectieGroepId])
}

enum TeamCategorie {
  SENIOREN
  A_CATEGORIE
  B_CATEGORIE
}

enum Kleur {
  PAARS
  BLAUW
  GROEN
  GEEL
  ORANJE
  ROOD
}

enum ValidatieStatus {
  GROEN
  ORANJE
  ROOD
  ONBEKEND
}

enum TeamType {
  VIERTAL
  ACHTTAL
}

// ============================================================
// TEAM-SPELER KOPPELING
// ============================================================

model TeamSpeler {
  id       String @id @default(cuid())
  team     Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId   String
  speler   Speler @relation(fields: [spelerId], references: [id])
  spelerId String

  statusOverride SpelerStatus?
  notitie        String? @db.Text

  @@unique([teamId, spelerId])
  @@index([teamId])
  @@index([spelerId])
}

enum SpelerStatus {
  BESCHIKBAAR
  TWIJFELT
  GAAT_STOPPEN
  NIEUW_POTENTIEEL
  NIEUW_DEFINITIEF
  ALGEMEEN_RESERVE
}

// ============================================================
// TEAM-STAF KOPPELING
// ============================================================

model TeamStaf {
  id     String @id @default(cuid())
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId String
  staf   Staf   @relation(fields: [stafId], references: [id])
  stafId String

  rol    String

  @@unique([teamId, stafId])
  @@index([teamId])
}

// ============================================================
// EVALUATIES (geïmporteerd uit Lovable evaluatie-app)
// ============================================================

model Evaluatie {
  id       String @id @default(cuid())
  speler   Speler @relation(fields: [spelerId], references: [id])
  spelerId String
  seizoen  String
  ronde    Int    @default(1)
  type     String @default("trainer")

  scores    Json
  opmerking String? @db.Text
  coach     String?
  teamNaam  String? @map("team_naam")

  rondeId         String?        @map("ronde_id")
  evaluatieRonde  EvaluatieRonde? @relation(fields: [rondeId], references: [id])
  coordinatorMemo String?        @map("coordinator_memo") @db.Text
  status          String         @default("concept")
  ingediendOp     DateTime?      @map("ingediend_op") @db.Timestamptz(6)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([spelerId, seizoen, ronde, type])
  @@index([seizoen])
  @@index([seizoen, ronde])
  @@index([type])
  @@index([rondeId])
}

// ============================================================
// BESLUITENLOG
// ============================================================

model LogEntry {
  id       String @id @default(cuid())
  versie   Versie @relation(fields: [versieId], references: [id], onDelete: Cascade)
  versieId String

  actie  String
  detail String? @db.Text
  door   User    @relation(fields: [doorId], references: [id])
  doorId String

  createdAt DateTime @default(now())

  @@index([versieId])
}

// ============================================================
// IMPORT-TRACKING
// ============================================================

model Import {
  id                String   @id @default(cuid())
  seizoen           String
  exportDatum       String
  snapshotDatum     String
  spelersNieuw      Int
  spelersBijgewerkt Int
  stafNieuw         Int
  stafBijgewerkt    Int
  teamsGeladen      Int
  meta              Json
  spelerIds         String[]
  diff              Json?
  createdAt         DateTime @default(now())

  @@index([seizoen])
}

// ============================================================
// REFERENTIE-TEAMS (huidige teamstructuur als referentie)
// ============================================================

model ReferentieTeam {
  id        String    @id @default(cuid())
  seizoen   String
  naam      String
  categorie String
  kleur     String?
  niveau    String?
  spelvorm  String?
  teamType  TeamType?
  poolVeld  String?
  poolZaal  String?
  spelerIds String[]
  stafIds   String[]
  stats     Json
  teamscore Int?
  createdAt DateTime  @default(now())

  @@index([seizoen])
}

// ============================================================
// WERKBORD & ACTIEPUNTEN
// ============================================================

enum WerkitemType {
  STRATEGISCH
  DATA
  REGEL
  TRAINER
  SPELER
  BESLUIT
}

enum WerkitemPrioriteit {
  BLOCKER
  HOOG
  MIDDEL
  LAAG
  INFO
}

enum WerkitemStatus {
  OPEN
  IN_BESPREKING
  OPGELOST
  GEACCEPTEERD_RISICO
  GEARCHIVEERD
}

enum Besluitniveau {
  TC
  BESTUUR
  TRAINER
}

enum Doelgroep {
  KWEEKVIJVER      // Kangoeroes, Blauw, Groen
  ONTWIKKELHART    // Geel, Oranje
  TOP              // U15, U17, U19, Senioren selectie
  WEDSTRIJDSPORT   // Senioren A (niet-selectie)
  KORFBALPLEZIER   // Rood (B), Senioren B
  ALLE
}

enum Entiteit {
  SPELER
  STAF
  TEAM
  BLAUWDRUK
}

enum ActiepuntStatus {
  OPEN
  BEZIG
  AFGEROND
}

model Werkitem {
  id           String   @id @default(cuid())
  blauwdruk    Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId  String

  titel        String
  beschrijving String   @db.Text
  type         WerkitemType
  prioriteit   WerkitemPrioriteit @default(MIDDEL)
  status       WerkitemStatus     @default(OPEN)
  besluitniveau Besluitniveau?
  doelgroep    Doelgroep?
  entiteit     Entiteit?

  // Optioneel scenario-niveau (null = blauwdruk-breed)
  scenario     Scenario? @relation(fields: [scenarioId], references: [id], onDelete: Cascade)
  scenarioId   String?

  // Optionele koppeling aan what-if
  whatIf       WhatIf?  @relation("WhatIfActies", fields: [whatIfId], references: [id], onDelete: Cascade)
  whatIfId     String?

  // Optionele koppelingen
  speler       Speler?  @relation(fields: [spelerId], references: [id])
  spelerId     String?
  staf         Staf?    @relation(fields: [stafId], references: [id])
  stafId       String?
  teamOwCode   String?

  // Oplossing
  resolutie    String?  @db.Text
  opgelostOp   DateTime?

  // Audit
  auteur       User     @relation("WerkitemAuteur", fields: [auteurId], references: [id])
  auteurId     String

  actiepunten  Actiepunt[]
  volgorde     Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([blauwdrukId])
  @@index([status])
  @@index([prioriteit])
}

model Actiepunt {
  id              String   @id @default(cuid())
  beschrijving    String   @db.Text
  status          ActiepuntStatus @default(OPEN)
  deadline        DateTime? @db.Date

  werkitem        Werkitem? @relation(fields: [werkitemId], references: [id], onDelete: Cascade)
  werkitemId      String?

  blauwdruk       Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId     String

  toegewezenAan   User     @relation("ActiepuntToewijzing", fields: [toegewezenAanId], references: [id])
  toegewezenAanId String

  auteur          User     @relation("ActiepuntAuteur", fields: [auteurId], references: [id])
  auteurId        String

  blauwdrukSpeler BlauwdrukSpeler? // terugrelatie: actiepunt gekoppeld aan gezien-status

  besluit         BlauwdrukBesluit? @relation(fields: [besluitId], references: [id])
  besluitId       String?

  afgerondOp      DateTime?
  volgorde        Int      @default(0)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([blauwdrukId])
  @@index([toegewezenAanId])
  @@index([status])
}

// ============================================================
// ACTIVITY TIMELINE
// ============================================================

model Activiteit {
  id        String         @id @default(cuid())
  type      ActiviteitType
  inhoud    String         @db.Text

  // Polymorf: precies één van deze is gevuld
  speler     Speler?  @relation(fields: [spelerId], references: [id])
  spelerId   String?
  staf       Staf?    @relation(fields: [stafId], references: [id])
  stafId     String?
  teamOwCode String?

  // Actiepunt-specifieke velden (null voor andere types)
  actiepuntStatus   ActiepuntStatus?
  deadline          DateTime?  @db.Date
  toegewezenAan     User?      @relation("ActiviteitToewijzing", fields: [toegewezenAanId], references: [id])
  toegewezenAanId   String?
  afgerondOp        DateTime?

  // Audit
  blauwdruk   Blauwdruk @relation(fields: [blauwdrukId], references: [id], onDelete: Cascade)
  blauwdrukId String
  auteur      User      @relation("ActiviteitAuteur", fields: [auteurId], references: [id])
  auteurId    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spelerId, createdAt])
  @@index([stafId, createdAt])
  @@index([blauwdrukId])
}

enum ActiviteitType {
  OPMERKING
  ACTIEPUNT
  STATUS_WIJZIGING
}

// ============================================================
// EVALUATIE-APP (rondes, uitnodigingen, zelfevaluaties)
// ============================================================

model EvaluatieRonde {
  id       String @id @default(cuid())
  seizoen  String
  ronde    Int
  naam     String
  type     String @default("trainer")
  deadline DateTime @db.Timestamptz(6)
  status   String @default("concept")

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  uitnodigingen EvaluatieUitnodiging[]
  evaluaties    Evaluatie[]

  @@unique([seizoen, ronde, type])
  @@map("evaluatie_rondes")
}

model Coordinator {
  id    String @id @default(cuid())
  naam  String
  email String @unique

  teams CoordinatorTeam[]

  createdAt DateTime @default(now())

  @@map("coordinatoren")
}

model CoordinatorTeam {
  id            String      @id @default(cuid())
  coordinatorId String
  coordinator   Coordinator @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)
  owTeamId      Int         @map("ow_team_id")
  owTeam        OWTeam      @relation(fields: [owTeamId], references: [id])
  seizoen       String

  @@unique([coordinatorId, owTeamId, seizoen])
  @@map("coordinator_teams")
}

model EvaluatieUitnodiging {
  id      String         @id @default(cuid())
  rondeId String
  ronde   EvaluatieRonde @relation(fields: [rondeId], references: [id], onDelete: Cascade)

  type    String
  email   String
  naam    String

  owTeamId Int?          @map("ow_team_id")
  owTeam   OWTeam?       @relation(fields: [owTeamId], references: [id])

  spelerId String?

  token    String @unique @default(cuid())

  emailVerstuurd    DateTime? @map("email_verstuurd") @db.Timestamptz(6)
  reminderVerstuurd DateTime? @map("reminder_verstuurd") @db.Timestamptz(6)
  reminderAantal    Int       @default(0) @map("reminder_aantal")

  createdAt DateTime @default(now())

  @@unique([rondeId, email, owTeamId])
  @@map("evaluatie_uitnodigingen")
}

model SpelerZelfEvaluatie {
  id       String @id @default(cuid())
  spelerId String
  speler   Speler @relation(fields: [spelerId], references: [id])
  seizoen  String
  ronde    Int    @default(1)
  rondeId  String?

  plezierKorfbal     Int? @map("plezier_korfbal")
  plezierTeam        Int? @map("plezier_team")
  plezierUitdaging   Int? @map("plezier_uitdaging")
  plezierToelichting String? @map("plezier_toelichting") @db.Text

  trainingZin         Int? @map("training_zin")
  trainingKwaliteit   Int? @map("training_kwaliteit")
  wedstrijdBeleving   Int? @map("wedstrijd_beleving")
  trainingVerbetering Int? @map("training_verbetering")
  trainingToelichting String? @map("training_toelichting") @db.Text

  toekomstIntentie    String? @map("toekomst_intentie")
  toekomstAmbitie     String? @map("toekomst_ambitie")
  toekomstToelichting String? @map("toekomst_toelichting") @db.Text

  algemeenOpmerking   String? @map("algemeen_opmerking") @db.Text

  coordinatorMemo         String?   @map("coordinator_memo") @db.Text
  status                  String    @default("concept")
  ingediendOp             DateTime? @map("ingediend_op") @db.Timestamptz(6)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([spelerId, seizoen, ronde])
  @@map("speler_zelf_evaluaties")
}

model EmailTemplate {
  id          String @id @default(cuid())
  sleutel     String @unique
  onderwerp   String
  inhoudHtml  String @map("inhoud_html") @db.Text

  updatedAt DateTime @default(now()) @updatedAt

  @@map("email_templates")
}

// ============================================================
// MIJLPALEN (dashboard agenda per seizoen)
// ============================================================

model Mijlpaal {
  id          String   @id @default(cuid())
  seizoen     String
  label       String
  datum       DateTime
  volgorde    Int      @default(0)
  afgerond    Boolean  @default(false)
  afgerondOp  DateTime?

  seizoenRef  Seizoen  @relation(fields: [seizoen], references: [seizoen])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([seizoen])
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  SCOUTING — OW Scout app (spelerskaarten, rapporten)     ║
// ║  Tabelnamen: snake_case (@@map)                          ║
// ╚═══════════════════════════════════════════════════════════╝

model Scout {
  id           String   @id @default(cuid())
  naam         String
  email        String   @unique
  userId       String?  @unique
  user         User?    @relation(fields: [userId], references: [id])
  stafId       String?  @unique
  staf         Staf?    @relation(fields: [stafId], references: [id])
  xp           Int      @default(0)
  level        Int      @default(1)
  rol          ScoutRol @default(SCOUT)
  vrijScouten  Boolean  @default(false) @map("vrij_scouten")

  rapporten      ScoutingRapport[]
  badges         ScoutBadge[]
  teamSessies    TeamScoutingSessie[]
  toewijzingen   ScoutToewijzing[]
  vergelijkingen ScoutingVergelijking[]
  fysiekProfielen FysiekProfiel[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("scouts")
}

model ScoutingRapport {
  id            String              @id @default(cuid())
  scoutId       String
  scout         Scout               @relation(fields: [scoutId], references: [id])
  spelerId      String
  speler        Speler              @relation(fields: [spelerId], references: [id])
  seizoen       String
  datum         DateTime            @default(now())
  context       ScoutingContext
  contextDetail String?
  scores        Json
  opmerking     String?             @db.Text
  overallScore  Int?
  teamSessieId  String?
  teamSessie    TeamScoutingSessie? @relation(fields: [teamSessieId], references: [id])
  verzoekId      String?             @map("verzoek_id")
  verzoek        ScoutingVerzoek?    @relation(fields: [verzoekId], references: [id])
  relatie        ScoutSpelerRelatie  @default(GEEN)
  nietBeoordeeld Boolean             @default(false) @map("niet_beoordeeld")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([spelerId, seizoen])
  @@index([scoutId, datum])
  @@index([teamSessieId])
  @@index([verzoekId])
  @@map("scouting_rapporten")
}

model TeamScoutingSessie {
  id            String          @id @default(cuid())
  scoutId       String
  scout         Scout           @relation(fields: [scoutId], references: [id])
  owTeamId      Int
  owTeam        OWTeam          @relation(fields: [owTeamId], references: [id])
  seizoen       String
  datum         DateTime        @default(now())
  context       ScoutingContext
  contextDetail String?
  rankings      Json?

  rapporten ScoutingRapport[]

  createdAt DateTime @default(now())

  @@index([owTeamId, seizoen])
  @@map("team_scouting_sessies")
}

enum ScoutingContext {
  WEDSTRIJD
  TRAINING
  OVERIG
}

enum ScoutRol {
  SCOUT // Reguliere scout: werkt op verzoek, optioneel vrij scouten
  TC    // TC-lid: maakt verzoeken, ziet alles, kan altijd scouten
}

enum VerzoekType {
  GENERIEK    // Beoordeel alle spelers van een team
  SPECIFIEK   // Beoordeel 1 speler met gerichte vraag
  VERGELIJKING // Vergelijk 2+ spelers
}

enum VerzoekStatus {
  OPEN        // Aangemaakt, nog niet alle scouts begonnen
  ACTIEF      // Minstens 1 scout is begonnen
  AFGEROND    // Alle toewijzingen afgerond
  GEANNULEERD // Door TC geannuleerd
}

enum ToewijzingStatus {
  UITGENODIGD  // Scout is uitgenodigd
  GEACCEPTEERD // Scout heeft geaccepteerd
  AFGEWEZEN    // Scout heeft afgewezen
  AFGEROND     // Scout heeft rapport(en) ingediend
  GESTOPT      // Scout is halverwege gestopt
}

enum VerzoekDoel {
  DOORSTROOM      // Speler beoordelen voor promotie/degradatie
  SELECTIE        // Speler beoordelen voor A-categorie selectie
  NIVEAUBEPALING  // Algemene niveaubepaling
  OVERIG          // Anders
}

enum ScoutSpelerRelatie {
  GEEN     // Geen persoonlijke relatie
  OUDER    // Scout is ouder van speler
  FAMILIE  // Overige familieband
  BEKENDE  // Persoonlijke bekende
  TRAINER  // Scout is (ook) trainer van speler
}

// ── Scouting Verzoeken ────────────────────────────────────────

model ScoutingVerzoek {
  id              String        @id @default(cuid())
  type            VerzoekType
  doel            VerzoekDoel   @default(NIVEAUBEPALING)
  status          VerzoekStatus @default(OPEN)
  toelichting     String?       @db.Text
  deadline        DateTime?
  anoniem         Boolean       @default(false) // Rapporten anoniem tonen aan niet-TC

  // Scope
  teamId          String?       @map("team_id")
  spelerIds       String[]      @map("speler_ids")
  seizoen         String

  // Maker (TC-lid)
  aangemaakt_door String        @map("aangemaakt_door")
  maker           User          @relation(fields: [aangemaakt_door], references: [id])

  // Relaties
  toewijzingen    ScoutToewijzing[]
  rapporten       ScoutingRapport[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([seizoen])
  @@index([status])
  @@map("scouting_verzoeken")
}

model ScoutToewijzing {
  id        String           @id @default(cuid())
  verzoekId String           @map("verzoek_id")
  verzoek   ScoutingVerzoek  @relation(fields: [verzoekId], references: [id], onDelete: Cascade)
  scoutId   String           @map("scout_id")
  scout     Scout            @relation(fields: [scoutId], references: [id])
  status    ToewijzingStatus @default(UITGENODIGD)

  createdAt DateTime @default(now())

  @@unique([verzoekId, scoutId])
  @@index([scoutId])
  @@map("scout_toewijzingen")
}

model SpelersKaart {
  id              String   @id @default(cuid())
  spelerId        String
  speler          Speler   @relation(fields: [spelerId], references: [id])
  seizoen         String
  overall         Int
  pijlerScores    Json?    // v3.0: { "AANVALLEN": 78, "VERDEDIGEN": 65, ... }
  aantalRapporten Int      @default(0)
  betrouwbaarheid String   @default("concept")
  laatsteUpdate   DateTime @default(now())
  trendOverall    Int?     @default(0)
  leeftijdsgroep  String?  // "blauw" | "groen" | ... (snapshot)

  // DEPRECATED kolommen (behouden voor backward compatibility, niet meer geschreven)
  schot           Int?     // @deprecated — gebruik pijlerScores
  aanval          Int?     // @deprecated
  passing         Int?     // @deprecated
  verdediging     Int?     // @deprecated
  fysiek          Int?     // @deprecated
  mentaal         Int?     // @deprecated

  @@unique([spelerId, seizoen])
  @@map("spelers_kaarten")
}

model ScoutBadge {
  id         String   @id @default(cuid())
  scoutId    String
  scout      Scout    @relation(fields: [scoutId], references: [id])
  badge      String
  unlockedAt DateTime @default(now())

  @@unique([scoutId, badge])
  @@map("scout_badges")
}

model ScoutChallenge {
  id           String   @id @default(cuid())
  naam         String
  beschrijving String
  xpBeloning   Int
  startDatum   DateTime
  eindDatum    DateTime
  seizoen      String
  voorwaarde   Json

  createdAt DateTime @default(now())

  @@map("scout_challenges")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  RAAMWERK — Beheer van scouting-items per seizoen        ║
// ╚═══════════════════════════════════════════════════════════╝

enum RaamwerkStatus {
  CONCEPT      // Bewerkbaar door TC
  ACTIEF       // In gebruik door scouts (immutable)
  GEARCHIVEERD // Seizoen voorbij (frozen)
}

// Eén raamwerkversie per seizoen
model RaamwerkVersie {
  id             String          @id @default(cuid())
  seizoen        String          @unique
  naam           String          // bijv. "Vaardigheidsraamwerk v1.1"
  status         RaamwerkStatus  @default(CONCEPT)
  opmerking      String?         @db.Text
  bronVersieId   String?         @map("bron_versie_id") // gekopieerd van

  groepen        Leeftijdsgroep[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  gepubliceerdOp DateTime? @map("gepubliceerd_op")

  @@map("raamwerk_versies")
}

// Eén groep per band (paars, blauw, groen, geel, oranje, rood) per versie
model Leeftijdsgroep {
  id         String           @id @default(cuid())
  versieId   String           @map("versie_id")
  versie     RaamwerkVersie   @relation(fields: [versieId], references: [id], onDelete: Cascade)
  band       String           // "paars" | "blauw" | "groen" | "geel" | "oranje" | "rood"
  schaalType String           @map("schaal_type") // "observatie" | "ja_nogniet" | "goed_oke_nogniet" | "sterren" | "slider"
  maxScore   Int              @map("max_score")   // 1 | 2 | 3 | 5 | 10
  doelAantal Int              @default(0) @map("doel_aantal") // Target items uit raamwerk

  // USS v2 schaalparameters
  schaalMin        Decimal?  @map("schaal_min") @db.Decimal(6, 2)     // 0 | 1.0
  schaalMax        Decimal?  @map("schaal_max") @db.Decimal(6, 2)     // 100 | 5.0 | 10.0
  schaalMediaan    Decimal?  @map("schaal_mediaan") @db.Decimal(6, 2) // 50 | 3.0 | 5.5
  halveBereik      Decimal?  @map("halve_bereik") @db.Decimal(6, 2)   // 50 | 2.0 | 4.5
  bandbreedteCoach Int?      @map("bandbreedte_coach")                // B_coach (USS-punten)
  bandbreedteScout Int?      @map("bandbreedte_scout")                // B_scout (USS-punten)
  kernItemsTarget  Int?      @map("kern_items_target")                // ~10

  pijlers    Pijler[]

  @@unique([versieId, band])
  @@map("leeftijdsgroepen")
}

// Pijlers per groep (Inside Out: blauw heeft 5, groen 5, geel 6, oranje 7, rood 9)
model Pijler {
  id       String           @id @default(cuid())
  groepId  String           @map("groep_id")
  groep    Leeftijdsgroep   @relation(fields: [groepId], references: [id], onDelete: Cascade)
  code     String           // v3.0: "BAL" | "BEWEGEN" | "SPEL" | "SAMEN" | "IK" |
                            //        "AANVALLEN" | "VERDEDIGEN" | "TECHNIEK" | "TACTIEK" |
                            //        "MENTAAL" | "FYSIEK" | "SOCIAAL" | "SCOREN" | "SPELINTELLIGENTIE"
  naam     String
  icoon    String?          // Emoji
  volgorde Int              @default(0)
  blok     String?          // "korfbalacties" | "spelerskwaliteiten" | "persoonlijk" | null
  gewicht  Decimal?         @db.Decimal(4, 2)  // USS-gewicht (bijv. 0.18)

  items    OntwikkelItem[]

  @@unique([groepId, code])
  @@map("pijlers")
}

// Individuele beoordelingsitems (vragen)
model OntwikkelItem {
  id          String           @id @default(cuid())
  pijlerId    String           @map("pijler_id")
  pijler      Pijler           @relation(fields: [pijlerId], references: [id], onDelete: Cascade)
  itemCode    String           @map("item_code")   // bijv. "aan_vrijlopen"
  label       String           // Korte naam
  vraagTekst  String           @map("vraag_tekst") // Volledige formulering
  laag        String?          // DEPRECATED: vervangen door isKern
  isKern      Boolean          @default(true) @map("is_kern")       // kern-item voor TEAM-methode
  categorie   String?          // "KERN" | "ONDERSCHEIDEND" (alleen Rood)
  observatie  String?          @db.Text // Observatie-instructie (hoe herken je dit item)
  volgorde    Int              @default(0)
  actief      Boolean          @default(true)

  // Meegroei: link naar voorloper in jongere band
  voorloperId String?          @map("voorloper_id")
  voorloper   OntwikkelItem?   @relation("ItemVoorloper", fields: [voorloperId], references: [id])
  opvolgers   OntwikkelItem[]  @relation("ItemVoorloper")

  @@unique([pijlerId, itemCode])
  @@index([pijlerId, volgorde])
  @@map("ontwikkel_items")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  USS v2 — Fysiek profiel, gecachte USS, vergelijkingen   ║
// ╚═══════════════════════════════════════════════════════════╝

// Fysiek profiel: contextdata per speler per seizoen (geen USS-impact)
model FysiekProfiel {
  id           String            @id @default(cuid())
  spelerId     String
  speler       Speler            @relation(fields: [spelerId], references: [id])
  seizoen      String
  scoutId      String?
  scout        Scout?            @relation(fields: [scoutId], references: [id])

  lengte       LengteRelatief?
  lichaamsbouw Lichaamsbouw?
  atletischType AtetischType?    @map("atletisch_type")
  opmerking    String?           @db.Text

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@unique([spelerId, seizoen])
  @@index([spelerId])
  @@map("fysiek_profielen")
}

enum LengteRelatief {
  ONDER_GEMIDDELD
  GEMIDDELD
  BOVENGEMIDDELD
  UITZONDERLIJK
}

enum Lichaamsbouw {
  LICHT
  GEMIDDELD_LB  // Enum-variant nodig want GEMIDDELD is al bezet
  STEVIG
}

enum AtetischType {
  ONDER_GEMIDDELD_AT
  GEMIDDELD_AT
  BOVENGEMIDDELD_AT
  UITZONDERLIJK_AT
}

// Gecachte USS-berekening per speler per seizoen
model SpelerUSS {
  id             String   @id @default(cuid())
  spelerId       String
  speler         Speler   @relation(fields: [spelerId], references: [id])
  seizoen        String
  leeftijdsgroep String   @map("leeftijdsgroep") // snapshot: "blauw" | "groen" | ...

  // Overall USS
  ussOverall     Int?     @map("uss_overall")

  // Per-pijler USS (JSON voor variabele pijlers)
  ussPijlers     Json?    @map("uss_pijlers")  // { "AANVALLEN": 121, "VERDEDIGEN": 106, ... }

  // Bron-USS waarden
  ussCoach       Int?     @map("uss_coach")
  ussScout       Int?     @map("uss_scout")
  ussVergelijking Int?    @map("uss_vergelijking")
  ussTeam        Int?     @map("uss_team")         // anker
  ussBasislijn   Int?     @map("uss_basislijn")     // S(leeftijd)

  // Per-bron per-pijler (JSON)
  ussCoachPijlers       Json?  @map("uss_coach_pijlers")
  ussScoutPijlers       Json?  @map("uss_scout_pijlers")
  ussVergelijkingPijlers Json? @map("uss_vergelijking_pijlers")

  // Meta
  aantalCoachSessies     Int @default(0) @map("aantal_coach_sessies")
  aantalScoutSessies     Int @default(0) @map("aantal_scout_sessies")
  aantalVergelijkingen   Int @default(0) @map("aantal_vergelijkingen")
  betrouwbaarheid        String @default("concept")

  // Cross-validatie signalen
  crossValidatieSignalen Json?  @map("cross_validatie_signalen") // [{ pijler, verschil, type }]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([spelerId, seizoen])
  @@index([spelerId])
  @@index([seizoen])
  @@map("speler_uss")
}

// Vergelijkende scouting: 2-6 spelers op een horizontale balk per pijler
model ScoutingVergelijking {
  id          String   @id @default(cuid())
  scoutId     String
  scout       Scout    @relation(fields: [scoutId], references: [id])
  seizoen     String
  datum       DateTime @default(now())
  context     ScoutingContext
  opmerking   String?  @db.Text

  // Scope
  teamId      Int?     @map("team_id")  // optioneel: vergelijking binnen team
  verzoekId   String?  @map("verzoek_id")

  posities    ScoutingVergelijkingPositie[]

  createdAt   DateTime @default(now())

  @@index([seizoen])
  @@index([scoutId])
  @@map("scouting_vergelijkingen")
}

model ScoutingVergelijkingPositie {
  id              String   @id @default(cuid())
  vergelijkingId  String   @map("vergelijking_id")
  vergelijking    ScoutingVergelijking @relation(fields: [vergelijkingId], references: [id], onDelete: Cascade)
  spelerId        String
  speler          Speler   @relation(fields: [spelerId], references: [id])
  pijlerCode      String   @map("pijler_code")  // "AANVALLEN", "VERDEDIGEN", etc.
  balkPositie     Decimal  @map("balk_positie") @db.Decimal(5, 2) // 0.00 - 100.00
  isAnker         Boolean  @default(false) @map("is_anker") // speler met bekende USS

  @@unique([vergelijkingId, spelerId, pijlerCode])
  @@index([vergelijkingId])
  @@index([spelerId])
  @@map("scouting_vergelijking_posities")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  WERVING — Aanmeldingsfunnel (beheer-app)                ║
// ╚═══════════════════════════════════════════════════════════╝

enum AanmeldingStatus {
  AANMELDING    // Eerste contact
  PROEFLES      // Proefles ingepland
  INTAKE        // Intake gesprek
  LID           // Volwaardig lid geworden
  AFGEHAAKT     // Niet doorgegaan
}

model Aanmelding {
  id            String           @id @default(cuid())
  naam          String
  email         String?
  telefoon      String?
  geboortejaar  Int?
  opmerking     String?          @db.Text
  status        AanmeldingStatus @default(AANMELDING)
  bron          String?          // "website" | "bekende" | "open dag" | etc.

  // Verantwoordelijken
  ledenadmin    String?          @map("ledenadmin")
  trainer       String?
  tcLid         String?          @map("tc_lid")

  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  @@map("aanmeldingen")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  WHAT-IF (lichtgewicht branches op werkindeling)         ║
// ╚═══════════════════════════════════════════════════════════╝

enum WhatIfStatus {
  OPEN
  BESLISBAAR
  TOEGEPAST
  VERWORPEN
}

model WhatIf {
  id                    String        @id @default(cuid())
  werkindelingId        String
  werkindeling          Scenario      @relation(fields: [werkindelingId], references: [id], onDelete: Cascade)

  vraag                 String
  toelichting           String?       @db.Text

  status                WhatIfStatus  @default(OPEN)

  basisVersieNummer     Int

  toelichtingAfwijking  String?       @db.Text
  toegepastOp           DateTime?
  verworpenOp           DateTime?

  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  teams                 WhatIfTeam[]
  acties                Werkitem[]    @relation("WhatIfActies")

  @@index([werkindelingId])
  @@index([status])
  @@map("what_ifs")
}

model WhatIfTeam {
  id            String        @id @default(cuid())
  whatIfId       String
  whatIf         WhatIf        @relation(fields: [whatIfId], references: [id], onDelete: Cascade)

  bronTeamId    String?
  bronTeam      Team?         @relation(fields: [bronTeamId], references: [id])

  naam          String
  categorie     TeamCategorie
  kleur         Kleur?
  teamType      TeamType?
  niveau        String?
  volgorde      Int           @default(0)

  spelers       WhatIfTeamSpeler[]
  staf          WhatIfTeamStaf[]

  @@index([whatIfId])
  @@index([bronTeamId])
  @@map("what_if_teams")
}

model WhatIfTeamSpeler {
  id              String          @id @default(cuid())
  whatIfTeamId     String
  whatIfTeam       WhatIfTeam      @relation(fields: [whatIfTeamId], references: [id], onDelete: Cascade)
  spelerId        String
  speler          Speler          @relation(fields: [spelerId], references: [id])

  statusOverride  SpelerStatus?
  notitie         String?         @db.Text

  @@unique([whatIfTeamId, spelerId])
  @@index([whatIfTeamId])
  @@index([spelerId])
  @@map("what_if_team_spelers")
}

model WhatIfTeamStaf {
  id              String      @id @default(cuid())
  whatIfTeamId     String
  whatIfTeam       WhatIfTeam  @relation(fields: [whatIfTeamId], references: [id], onDelete: Cascade)
  stafId          String
  staf            Staf        @relation(fields: [stafId], references: [id])

  rol             String?

  @@unique([whatIfTeamId, stafId])
  @@index([whatIfTeamId])
  @@map("what_if_team_staf")
}

// ╔═══════════════════════════════════════════════════════════╗
// ║  DAISY — AI-commissielid chat                            ║
// ╚═══════════════════════════════════════════════════════════╝

enum BerichtRol {
  GEBRUIKER
  ASSISTENT
  SYSTEEM
  TOOL
}

model AiProviderInstelling {
  id             String   @id @default(cuid())
  provider       String   @default("auto") // "auto" | "claude" | "gemini"
  claudeModel    String   @default("claude-sonnet-4-6") @map("claude_model")
  geminiModel    String   @default("gemini-2.0-flash") @map("gemini_model")
  maxTokens      Int      @default(1024) @map("max_tokens")
  bijgewerktOp   DateTime @updatedAt @map("bijgewerkt_op")
  bijgewerktDoor String?  @map("bijgewerkt_door")

  @@map("ai_provider_instelling")
}

model AiGesprek {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  seizoen   String
  titel     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  berichten AiBericht[]

  @@map("ai_gesprekken")
}

model AiBericht {
  id        String     @id @default(cuid())
  gesprekId String     @map("gesprek_id")
  gesprek   AiGesprek  @relation(fields: [gesprekId], references: [id], onDelete: Cascade)
  rol       BerichtRol
  inhoud    String
  metadata  Json?
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("ai_berichten")
}
